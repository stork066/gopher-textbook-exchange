{
  "name": "my-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=client",
    "start": "node server/src/index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
