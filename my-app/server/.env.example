# ── Local development ───────────────────────────────────────────────
PORT=3001
DYNAMODB_ENDPOINT=http://127.0.0.1:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── Production (EC2 / real AWS DynamoDB) ────────────────────────────
# NODE_ENV=production
# PORT=80  (or 3001 behind a reverse proxy)
# AWS_REGION=us-east-1
# DYNAMODB_ENDPOINT= (leave UNSET — SDK uses real AWS)
# If using an EC2 instance role, omit the access key/secret below too.
# Otherwise:
# AWS_ACCESS_KEY_ID=<IAM user access key>
# AWS_SECRET_ACCESS_KEY=<IAM user secret>
# JWT_SECRET=<strong random string, different from dev>
# JWT_EXPIRES_IN=7d
